{
  "name": "cypherclaw",
  "version": "0.1.0",
  "description": "A personal AI assistant built from scratch",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cypherclaw": "bin/cypherclaw.mjs"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test src/**/test/*.test.ts",
    "dev": "tsx src/index.ts",
    "start": "npx tsx src/entry.ts chat --debug",
    "cypherclaw": "node --import tsx src/cli/index.ts",
    "chat": "npx tsx src/entry.ts chat",
    "chat-debug": "npx tsx src/entry.ts chat --debug",
    "chat-debug-raw": "npx tsx src/entry.ts chat --debug --raw",
    "chat-debug-raw-tools": "npx tsx src/entry.ts chat --debug --raw --tool-confirm",
    "chat-debug-tools": "npx tsx src/entry.ts chat --debug --tool-confirm",
    "gateway": "npx tsx src/entry.ts start --foreground",
    "gateway:dev": "npx tsx --watch src/entry.ts start --foreground",
    "gateway:daemon": "npx tsx src/gateway/daemon.ts",
    "gateway:start": "npx tsx src/entry.ts start",
    "gateway:restart": "npx tsx src/entry.ts stop && npx tsx src/entry.ts start",
    "gateway:stop": "npx tsx src/entry.ts stop",
    "gateway:status": "npx tsx src/entry.ts status",
    "prod:start": "node --env-file=.env dist/entry.js start",
    "prod:stop": "node --env-file=.env dist/entry.js stop",
    "prod:status": "node --env-file=.env dist/entry.js status",
    "token:create": "npx tsx src/entry.ts token create",
    "token:list": "npx tsx src/entry.ts token list",
    "token:revoke": "npx tsx src/entry.ts token revoke"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "linkedom": "^0.18.12",
    "playwright-core": "^1.52.0",
    "tslog": "^4.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
