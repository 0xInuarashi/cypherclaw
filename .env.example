# ─── Provider selection ────────────────────────────────────────────────────────
# Which LLM backend to use. Pick exactly one:
#   openai      → calls api.openai.com
#   anthropic   → calls api.anthropic.com
#   openrouter  → calls openrouter.ai (access to all models with one key)
CYPHERCLAW_PROVIDER=openai

# ─── API keys ──────────────────────────────────────────────────────────────────
# Only the key for the chosen provider is required. The others are ignored.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ─── Model override (optional) ─────────────────────────────────────────────────
# Leave commented out to use the built-in default for your provider:
#   openai      → gpt-4o-mini
#   anthropic   → claude-3-5-haiku-20241022
#   openrouter  → openai/gpt-4o-mini  (any openrouter model slug works here)
# CYPHERCLAW_MODEL=gpt-4o

# ─── System prompt (optional) ──────────────────────────────────────────────────
# Sets the agent's persona / instructions before the conversation starts.
# Can also be overridden at runtime with: cypherclaw chat --system "..."
# CYPHERCLAW_SYSTEM_PROMPT=You are a helpful assistant.

# ─── Browserbase (used by the web_fetch tool) ──────────────────────────────────
# Required for browser-backed web fetching:
# BROWSERBASE_API_KEY=bb_...
# BROWSERBASE_PROJECT_ID=proj_...
#
# Optional:
# - set BROWSERBASE_USE_PROXY=false if your plan or target sites do not support
#   Browserbase proxies.
# - set BROWSERBASE_ADVANCED_STEALTH=true only if your Browserbase plan supports it.
# BROWSERBASE_USE_PROXY=true
# BROWSERBASE_ADVANCED_STEALTH=false
