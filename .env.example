# ─── Provider selection ────────────────────────────────────────────────────────
# Which LLM backend to use. Pick exactly one:
#   openai      → calls api.openai.com
#   anthropic   → calls api.anthropic.com
#   openrouter  → calls openrouter.ai (access to all models with one key)
CYPHERCLAW_PROVIDER=openai

# ─── API keys ──────────────────────────────────────────────────────────────────
# Only the key for the chosen provider is required. The others are ignored.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ─── Model override (optional) ─────────────────────────────────────────────────
# Leave commented out to use the built-in default for your provider:
#   openai      → gpt-4o-mini
#   anthropic   → claude-3-5-haiku-20241022
#   openrouter  → openai/gpt-4o-mini  (any openrouter model slug works here)
# CYPHERCLAW_MODEL=gpt-4o

# ─── System prompt (optional) ──────────────────────────────────────────────────
# Sets the agent's persona / instructions before the conversation starts.
# Can also be overridden at runtime with: cypherclaw chat --system "..."
# CYPHERCLAW_SYSTEM_PROMPT=You are a helpful assistant.

# ─── Discord connector (optional) ──────────────────────────────────────────────
# When DISCORD_BOT_TOKEN and DISCORD_COMMANDER_IDS are both set, the Discord
# connector activates when you run: npx tsx src/entry.ts discord
#
# DISCORD_BOT_TOKEN        — your bot's token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# DISCORD_COMMANDER_IDS    — comma-separated Discord user IDs that the agent will obey
#                            (right-click a user → "Copy User ID" in Discord with Dev Mode on)
DISCORD_COMMANDER_IDS=123456789012345678,987654321098765432

# DISCORD_GUILD_IDS        — (optional) comma-separated guild IDs to restrict the bot to.
#                            If omitted, the bot responds in any guild (and DMs).
# DISCORD_GUILD_IDS=111122223333444455

# DISCORD_CHANNEL_IDS      — (optional) comma-separated channel IDs to restrict the bot to.
#                            If both GUILD_IDS and CHANNEL_IDS are set, BOTH must match.
# DISCORD_CHANNEL_IDS=555566667777888899
