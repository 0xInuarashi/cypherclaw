# ─── Provider selection ────────────────────────────────────────────────────────
# Which LLM backend to use. Pick exactly one:
#   openai      → calls api.openai.com
#   anthropic   → calls api.anthropic.com
#   openrouter  → calls openrouter.ai (access to all models with one key)
CYPHERCLAW_PROVIDER=openai

# ─── API keys ──────────────────────────────────────────────────────────────────
# Only the key for the chosen provider is required. The others are ignored.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ─── Model override (optional) ─────────────────────────────────────────────────
# Leave commented out to use the built-in default for your provider:
#   openai      → gpt-4o-mini
#   anthropic   → claude-3-5-haiku-20241022
#   openrouter  → openai/gpt-4o-mini  (any openrouter model slug works here)
# CYPHERCLAW_MODEL=gpt-4o

# ─── System prompt (optional) ──────────────────────────────────────────────────
# Sets the agent's persona / instructions before the conversation starts.
# Can also be overridden at runtime with: cypherclaw chat --system "..."
# CYPHERCLAW_SYSTEM_PROMPT=You are a helpful assistant.

# ─── web_fetch tool ────────────────────────────────────────────────────────────
# web_fetch uses a three-tier pipeline: native fetch → Jina Reader → Firecrawl.
# No keys are required for basic usage (tiers 1 and 2 work without any key).
#
# Jina Reader (r.jina.ai) — free, no key needed, but rate-limited without one.
# Also used by web_search (s.jina.ai). One key covers both tools.
# Get a free key at: https://jina.ai/reader
# JINA_API_KEY=jina_...
#
# Firecrawl — paid, highest quality, caching. Only used if this key is set.
# Get a key at: https://firecrawl.dev
# FIRECRAWL_API_KEY=fc-...

# ─── web_search tool ───────────────────────────────────────────────────────────
# web_search uses a six-tier pipeline. Tiers 1 and 2 work without any key.
# The tiers below tier 2 are skipped if the corresponding key is not set.
#
# Marginalia Search — free, independent index, no signup required.
# Uses key "public" by default (shared rate limit). Email contact@marginalia-search.com
# for a free dedicated key with a separate rate limit.
# MARGINALIA_API_KEY=...
#
# Brave Search — independent index, up to 20 results, high quality.
# Get a key at: https://brave.com/search/api/
# BRAVE_API_KEY=BSA...
#
# Tavily — purpose-built for LLM agents, with LLM-optimised snippets.
# Get a key at: https://tavily.com
# TAVILY_API_KEY=tvly-...
#
# Exa — neural/semantic search, great for research queries.
# Get a key at: https://exa.ai
# EXA_API_KEY=...